[Unit]
Description=Dump UniFi MongoDB for backup
OnFailure=unit-fail-mail@%n.service

[Service]
Type=exec
ExecStart={{ docker_path }} exec unifi-mongodb mongodump --authenticationDatabase admin -u {{ app_unifi_mongodb_user }} -p {{ app_unifi_mongodb_password }} -d unifi -o /backup/unifi
ExecStartPost={{ docker_path }} exec unifi-mongodb mongodump --authenticationDatabase admin -u {{ app_unifi_mongodb_user }} -p {{ app_unifi_mongodb_password }} -d unifi_stat -o /backup/unifi_stat
ExecStartPost={{ docker_path }} exec unifi-mongodb mongodump --authenticationDatabase admin -u {{ app_unifi_mongodb_user }} -p {{ app_unifi_mongodb_password }} -d unifi_audit -o /backup/unifi_audit
